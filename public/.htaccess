Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTP → HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # non-www → www
    RewriteCond %{HTTP_HOST} ^alhambra-web\.com$ [NC]
    RewriteRule ^ https://www.alhambra-web.com%{REQUEST_URI} [R=301,L]

    # ── Routes PHP ────────────────────────────────────────────────────────────
    RewriteRule ^api/contact/?$                    /api/contact.php                [L]
    RewriteRule ^api/chat/?$                       /api/chat.php                   [L]
    RewriteRule ^api/auth/webauthn/?$              /api/webauthn.php               [L,QSA]
    RewriteRule ^api/auth/?$                       /api/auth.php                   [L]
    RewriteRule ^api/upload-text/?$                /api/upload-text.php            [L]

    RewriteRule ^api/admin/send-prospect/?$        /api/admin/send-prospect.php    [L]
    RewriteRule ^api/admin/bookings/?$             /api/admin/bookings.php         [L]
    RewriteRule ^api/admin/config/?$               /api/admin/config.php           [L]

    RewriteRule ^api/data/site_projects/?$         /api/data/site_projects.php     [L]
    RewriteRule ^api/data/site_services/?$         /api/data/site_services.php     [L]
    RewriteRule ^api/data/test/?$                  /api/data/test.php              [L]
    RewriteRule ^api/data/([a-z_]+)/?$             /api/data.php?table=$1          [L,QSA]

    # ── Fichiers existants servis directement ────────────────────────────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ── Répertoires → index.html (Next.js static routing) ───────────────────
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ /$1index.html [L]

    # ── Catch-all : routes inconnues → statut 404 + page personnalisée ─────────
    RewriteRule ^ - [R=404,L]
</IfModule>

# ── En-têtes de sécurité ───────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Supprime les en-têtes qui révèlent la stack
    Header unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Compression Gzip / Deflate ─────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/ld+json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── Cache navigateur ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Polices et images — 1 an (assets immuables versionnés par Next.js)
    ExpiresByType font/woff                           "access plus 1 year"
    ExpiresByType font/woff2                          "access plus 1 year"
    ExpiresByType image/webp                          "access plus 1 year"
    ExpiresByType image/avif                          "access plus 1 year"
    ExpiresByType image/png                           "access plus 1 year"
    ExpiresByType image/jpg                           "access plus 1 year"
    ExpiresByType image/jpeg                          "access plus 1 year"
    ExpiresByType image/gif                           "access plus 1 year"
    ExpiresByType image/svg+xml                       "access plus 1 year"
    ExpiresByType image/x-icon                        "access plus 1 year"

    # JS / CSS Next.js (hachés) — 1 an
    ExpiresByType application/javascript              "access plus 1 year"
    ExpiresByType text/css                            "access plus 1 year"

    # HTML — pas de cache (contenu dynamique)
    ExpiresByType text/html                           "access plus 0 seconds"

    # Manifest / robots / sitemap — 1 semaine
    ExpiresByType application/json                    "access plus 1 week"
    ExpiresByType text/xml                            "access plus 1 week"
    ExpiresByType application/xml                     "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
    # Assets Next.js versionnés → cache immuable
    <FilesMatch "\.(js|css|woff|woff2|ttf|otf|webp|avif|png|jpg|jpeg|gif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML → ne pas mettre en cache
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# ── CORS pour les polices ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ── Types MIME ─────────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType font/woff                           .woff
    AddType font/woff2                          .woff2
    AddType image/webp                          .webp
    AddType image/avif                          .avif
    AddType application/manifest+json          .webmanifest .json
    AddType text/cache-manifest                 .appcache
    AddType text/plain                          .txt
</IfModule>

# ── Page d'erreur personnalisée ────────────────────────────────────────────────
ErrorDocument 404 /404/index.html
ErrorDocument 403 /404/index.html
ErrorDocument 500 /404/index.html
